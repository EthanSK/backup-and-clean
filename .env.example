# backup-and-clean configuration
#
# Copy this file to ~/.backup-and-clean.env and edit for your setup.
#
# SOURCE_DIRS: Colon-separated list of directories to back up from.
# BACKUP_DIR:  The destination directory where backups are stored.
# FILE_PATTERN: Glob pattern for files to process (default: *.mkv).
# LOG_FILE:    Where to write the log (default: ~/Desktop/backup-and-clean.log).
# APP_TITLE:   Title shown in dialogs (default: Backup & Clean).
# EMPTY_TRASH_ON_COMPLETE:
#   1 = after delete phase, automatically purge volume-local .Trashes for every
#       volume that received files, actually freeing the space.
#   0 = never auto-empty (existing behaviour).
#   unset (default) = in GUI mode, prompt with Empty Now / Leave in Trash;
#       in headless mode, leave files in trash unless --empty-trash is passed.
# PROGRESS_INTERVAL:
#   Seconds between in-progress copy progress lines (default: 10). Files
#   smaller than 50 MiB skip polling — they finish before the first tick.

SOURCE_DIRS="/path/to/source1:/path/to/source2"
BACKUP_DIR="/path/to/backup"
FILE_PATTERN="*.mkv"
LOG_FILE="$HOME/Desktop/backup-and-clean.log"
APP_TITLE="Backup & Clean"
# EMPTY_TRASH_ON_COMPLETE=1
# PROGRESS_INTERVAL=10
